# Bu faylni .env nomi bilan nusxalab, qiymatlarni to'ldiring.
# .env fayli hech qachon git'ga qo'shilmaydi (maxfiy ma'lumotlar!).

# @BotFather'dan olingan Telegram bot tokeni (2-bosqichda kerak bo'ladi)
TELEGRAM_BOT_TOKEN=

# Facebook Messenger + Instagram DM (docs/meta-setup.md'ga qarang).
# Ikkalasi ham bitta Meta App + bitta Page Access Token bilan ishlaydi.
META_VERIFY_TOKEN=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Claude API kaliti — https://platform.claude.com dan olinadi.
# Bo'sh qoldirsangiz, AI tahlil oddiy qoidalar (heuristika) bilan ishlaydi.
ANTHROPIC_API_KEY=

# SQLite baza fayli qayerda saqlanishi (Supabase yo'q bo'lganda ishlatiladi)
DATABASE_PATH=inbox.db

# --- Supabase (ikkalasi to'ldirilsa backend avtomatik Postgres'ga o'tadi) ---
# Supabase dashboard -> Project Settings -> API dan olinadi.
# SERVICE KEY — maxfiy! Faqat backend'da, hech qachon frontend'da ishlatilmaydi.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
