# Bu faylni .env.local nomi bilan nusxalab, qiymatlarni to'ldiring.
# NEXT_PUBLIC_ prefiksli o'zgaruvchilar brauzerga ochiq bo'ladi —
# bu yerga hech qachon maxfiy (service) kalit yozilmaydi!

# FastAPI backend manzili
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Supabase (Auth + Realtime) ---
# Supabase dashboard -> Project Settings -> API dan olinadi.
# ANON kalit ochiq bo'lishi mumkin — RLS himoya qiladi.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
