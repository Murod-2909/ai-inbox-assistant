# Bu faylni .env.local nomi bilan nusxalab, qiymatlarni to'ldiring.
# NEXT_PUBLIC_ prefiksli o'zgaruvchilar brauzerga ochiq bo'ladi —
# bu yerga hech qachon maxfiy (service) kalit yozilmaydi!

# FastAPI backend manzili
NEXT_PUBLIC_API_URL=http://localhost:8000

# Stripe (to'lov uchun)
# https://dashboard.stripe.com/apikeys dan olinadi
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (Realtime + Auth uchun)
# supabase.com da loyiha yaratgach, Project Settings → API dan:
# - Project URL → NEXT_PUBLIC_SUPABASE_URL
# - anon/public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# Bo'lmasa polling ishlatiladi (4 soniya interval)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
